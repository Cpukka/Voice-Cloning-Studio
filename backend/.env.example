# Database
DATABASE_URL=postgresql://user:password@localhost:5432/voice_cloning

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Storage (set USE_S3=false for local storage)
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_BUCKET_NAME=voice-cloning-studio
AWS_REGION=us-east-1
USE_S3=false

# Redis (optional)
REDIS_URL=redis://localhost:6379

# API Settings
API_VERSION=v1
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Voice Cloning
VOICE_MODEL_PATH=./models/voice_cloning
TTS_MODEL_PATH=./models/tts
MAX_AUDIO_DURATION=30
SAMPLE_RATE=22050